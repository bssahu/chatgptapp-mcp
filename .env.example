# Copy to .env and adjust for your environment

# Used in OAuth redirects and auth URLs returned from MCP tools (set to ngrok URL when tunneling)
PUBLIC_BASE_URL=http://localhost:8000

# AWS Bedrock — Anthropic Claude Sonnet (leave empty for retrieval-only fallback)
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# Mock OAuth2 client credentials (authorization code flow)
MOCK_OAUTH_CLIENT_ID=demo-client
MOCK_OAUTH_CLIENT_SECRET=demo-secret

# Session cookie name for browser OAuth demo
SESSION_COOKIE_NAME=mcp_session

# Defaults are fine inside Docker Compose; override only if you run mcp-server outside Compose
# MONGODB_URI=mongodb://localhost:27017
# QDRANT_URL=http://localhost:6333
